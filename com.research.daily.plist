<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.research.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/bartdelepeleer/trading_bot2/daily_research.sh</string>
    </array>

    <!-- Run at 8:00 AM and 4:00 PM ET (market hours) -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>3</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>22</integer>
            <key>Minute</key>
            <integer>3</integer>
        </dict>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/bartdelepeleer/trading_bot2</string>

    <key>StandardOutPath</key>
    <string>/Users/bartdelepeleer/trading_bot2/logs/launchd_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/bartdelepeleer/trading_bot2/logs/launchd_stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
